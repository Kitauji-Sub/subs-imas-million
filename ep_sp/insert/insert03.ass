Comment: 0,0:00:00.00,0:00:00.00,歌JP,,0,0,0,code once,function AutoTagsList(Interval, Pause, List, Index)     local RESULT = ""     local ARGS = List     local count = math.ceil(line.duration / Interval)     for i = 1, count do         local LUCK = ARGS[(Index - i - 1) % #ARGS + 1]         RESULT = RESULT .. "\\t(" .. (i - 1) * Interval + Pause ..         "," .. i * Interval + Pause * (i - 1) .. ",\\" .. LUCK .. ")"     end     return RESULT end
