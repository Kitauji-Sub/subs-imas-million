Comment: 0,0:00:00.00,0:00:00.00,歌JP,,0,0,0,code once,function GetTags(text)     local tagTable = {}     tagTable.pos, tagTable.fsc, tagTable.fr, tagTable.fa, tagTable.color, tagTable.alpha, tagTable.move = {}, {}, {}, {}, {}, {}, {}     tagTable.italics = text:match("\\i(%d)")     tagTable.bold = text:match("\\b(%d+)%p")     tagTable.underlined = text:match("\\u(%d)")     tagTable.striked = text:match("\\s(%d)")     tagTable.bord = text:match("\\bord(%d+%p*%d*)%p")     tagTable.shad = text:match("\\shad(%d+%p*%d*)%p")     tagTable.be = text:match("\\be(%d+)%p")     tagTable.blur = text:match("\\blur(%d+%p*%d*)%p")     tagTable.fs = text:match("\\fs(%d+)%p")     tagTable.fsc.x, tagTable.fsc.y = text:match("\\fscx(%d+%p*%d*)%p"), text:match("\\fscy(%d+%p*%d*)%p")     tagTable.fsp = text:match("\\fsp(%p*%d+%p*%d*)%p")     tagTable.fr.x, tagTable.fr.y, tagTable.fr.z = text:match("\\frx(%p*%d+%p*%d*)%p"), text:match("\\fry(%p*%d+%p*%d*)%p"), text:match("\\frz(%p*%d+%p*%d*)%p")     tagTable.fa.x, tagTable.fa.y = text:match("\\fax(%p*%d+%p*%d*)%p"), text:match("\\fay(%p*%d+%p*%d*)%p")     tagTable.color.primary = text:match("\\c(&H%w%w%w%w%w%w&)") and text:match("\\c(&H%w%w%w%w%w%w&)") or text:match("\\1c(&H%w%w%w%w%w%w&)")     tagTable.color.secondary = text:match("\\2c(&H%w%w%w%w%w%w&)")     tagTable.color.border = text:match("\\3c(&H%w%w%w%w%w%w&)")     tagTable.color.shadow = text:match("\\4c(&H%w%w%w%w%w%w&)")     tagTable.alpha = {}     tagTable.alpha.all, tagTable.alpha.primary, tagTable.alpha.secondary, tagTable.alpha.border, tagTable.alpha.shadow = text:match("\\alpha(&H%w%w)"), text:match("\\1a(&H%w%w)"), text:match("\\2a(&H%w%w)"), text:match("\\3a(&H%w%w)"), text:match("\\4a(&H%w%w)")     tagTable.an = text:match("\\an(%d)")     tagTable.a = text:match("\\a(%d)")     tagTable.pos.x, tagTable.pos.y = text:match("\\pos%p(%d+%.*%d*)%p(%d+%.*%d*)%p")     tagTable.move.x1, tagTable.move.y1, tagTable.move.x2, tagTable.move.y2,tagTable.move.t1,tagTable.move.t2 = text:match("\\move%p(%-*%d+%.*%d*)%p(%-*%d+%.*%d*)%p(%-*%d+%.*%d*)%p(%-*%d+%.*%d*)%p(%-*%d*%.*%d*)%p(%-*%d*%.*%d*)%p")     return tagTable end
